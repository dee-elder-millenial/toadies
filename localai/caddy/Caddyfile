{
  auto_https off
  log {
    output stdout
    level INFO
  }
}

# Plain-HTTP front door: bounce everything to HTTPS. No cert needed here.
:80 {
  redir https://{host}{uri}
}

# Shared TLS + reverse-proxy to the host's Ollama (127.0.0.1:11434).
# Ollama stays bound to localhost; only Caddy faces the LAN.
(ollama) {
  tls /etc/caddy/certs/localai.crt /etc/caddy/certs/localai.key
  reverse_proxy 127.0.0.1:11434 {
    header_up Host 127.0.0.1:11434
  }
}

:443 {
  import ollama
}

:8443 {
  import ollama
}

# Container path: serve Ollama's DEFAULT port 11434 but bind ONLY the docker-bridge
# gateway IP (172.17.0.1) so it does NOT collide with Ollama's own 127.0.0.1:11434.
# The Open WebUI container's host.docker.internal:11434 then reaches Ollama with no
# config change. Plain HTTP (no cert). (Accepted: reachable to docker + LAN.)
http://:11434 {
  bind 172.17.0.1
  reverse_proxy 127.0.0.1:11434 {
    header_up Host 127.0.0.1:11434
  }
}

# Bonus: plain-HTTP Ollama on :11435 LAN-wide (optional alternate URL).
:11435 {
  reverse_proxy 127.0.0.1:11434 {
    header_up Host 127.0.0.1:11434
  }
}
